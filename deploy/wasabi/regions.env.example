# Copy to regions.env and edit. Exported variables drive
# provision_buckets.sh.

# Root operator credentials (NOT the per-region runtime credential
# used by the gateway). Provision per-region IAM users separately
# via the Wasabi console once buckets exist.
export WASABI_ROOT_ACCESS_KEY="AKIA-REPLACE-ME"
export WASABI_ROOT_SECRET_KEY="REPLACE-ME"

# Environment tag baked into the bucket name (zkof-{region}-{env}).
export ZKOF_ENV="prod"

# Newline-delimited region:endpoint pairs. Endpoints come from
# https://wasabi.com/wasabi-locations-faq/.
export WASABI_REGIONS=$(cat <<'EOF'
us-east-1:https://s3.us-east-1.wasabisys.com
us-east-2:https://s3.us-east-2.wasabisys.com
us-west-1:https://s3.us-west-1.wasabisys.com
eu-central-1:https://s3.eu-central-1.wasabisys.com
eu-west-1:https://s3.eu-west-1.wasabisys.com
ap-northeast-1:https://s3.ap-northeast-1.wasabisys.com
EOF
)
