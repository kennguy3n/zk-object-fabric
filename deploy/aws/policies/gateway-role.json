{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "KMSEncryptDecrypt",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "@@KMS_KEY_ARN@@"
    },
    {
      "Sid": "S3BYOCObjectIO",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListBucketMultipartUploads",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::@@BYOC_BUCKET@@",
        "arn:aws:s3:::@@BYOC_BUCKET@@/*"
      ]
    },
    {
      "Sid": "RDSConnect",
      "Effect": "Allow",
      "Action": ["rds-db:connect"],
      "Resource": "arn:aws:rds-db:@@AWS_REGION@@:@@AWS_ACCOUNT@@:dbuser:@@RDS_RESOURCE_ID@@/zkof_gateway"
    },
    {
      "Sid": "CloudWatchPutLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*"
    }
  ]
}
